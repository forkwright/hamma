{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "separate-pull-requests": false,
  "packages": {
    ".": {
      "package-name": "hamma",
      "component": "hamma",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.package.version"
        }
      ],
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "refactor",
          "section": "Refactoring"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "test",
          "hidden": true
        },
        {
          "type": "chore",
          "hidden": true
        },
        {
          "type": "ci",
          "hidden": true
        },
        {
          "type": "style",
          "hidden": true
        },
        {
          "type": "build",
          "hidden": true
        }
      ]
    }
  }
}
